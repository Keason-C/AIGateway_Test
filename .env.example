# Required — your gateway API key for the assistant under test
ZF_API_KEY=replace-me

# Optional — defaults shown
ZF_BASE_URL=https://ai-assistant-suite-staging.azurewebsites.net/v1
ZF_MODEL=pureGPT

# Optional — if pureGPT has no server-side tools, point this at an assistant that does
# ZF_TOOL_MODEL=AIWEB_TEST

# Optional skip flags (set to 1 to skip)
SKIP_CONCURRENCY=0
SKIP_CONTEXT_LIMIT=0
SKIP_MAF=0

# Optional tuning
CONCURRENCY_LEVELS=1,5,10,20,50,100
CONTEXT_UPPER_TOKENS=200000
